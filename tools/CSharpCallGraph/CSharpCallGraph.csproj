<Project Sdk="Microsoft.NET.Sdk">

  <!-- Optional, opt-in C# call-graph provider for the Repository Visualizer.
       It is NOT part of the offline browser app and is never required to run it.
       The Node CLI/API invokes it (via `dotnet`) ONLY when a C# project is analyzed
       and the .NET SDK is present; otherwise the regex heuristic is used. -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <RollForward>LatestMajor</RollForward>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>disable</Nullable>
    <LangVersion>latest</LangVersion>
    <AssemblyName>CSharpCallGraph</AssemblyName>
    <RootNamespace>CSharpCallGraph</RootNamespace>
    <InvariantGlobalization>true</InvariantGlobalization>
    <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.11.0" />
  </ItemGroup>

</Project>
